// nextflow.config file. Loaded by default 
// Modified from base generated by seqera AI for conda > mamba > lockfiles with wave

// enable dsl2 syntax
nextflow.enable.dsl = 2


// -------------------------
// Default Settings: will be overridden by profiles
// -------------------------
conda {
    enabled = true
    useMicromamba = true
    cacheDir = '/home/pbk1/micromamba/other-envs'  // For clusters
    channels = ['bioconda', 'conda-forge']
}

// wave {
//     enabled = true
//     freeze = true  // Generates lock files automatically
//     // needs a tower.accessToken to use this without servece rate limits
//     // https://www.nextflow.io/docs/latest/wave.html#wave-page
// }

// -------------------------
// Profiles
// -------------------------
profiles {
    // conda {
    //     conda.enabled = true
    //     conda.useMicromamba = true
    //     conda.cacheDir = '/home/pbk1/micromamba/other-envs'
    // }
    
    apptainer {
        // Use apptainer instead of conda
        apptainer.enabled = true
        apptainer.cacheDir = './apptainer'
        conda.enabled = false
    }
}