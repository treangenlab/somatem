/*
 * Nextflow Configuration for Marlin Complete Subworkflow
 * 
 * This config enables:
 * - Automatic conda environment creation
 * - Dynamic resource allocation based on system specs
 * - Sensible defaults for all parameters
 * - Per-process resource and conda requirements
 * 
 * Compatible with Nextflow 25.10+ strict syntax mode
 */

// ========================================
// Global Configuration
// ========================================

// Automatic system resource detection
def availableCpus = Runtime.runtime.availableProcessors()
def availableMemoryGB = (Runtime.runtime.maxMemory() / 1073741824) as int

// Conservative resource allocation (use 80% of available)
def maxCpus = Math.max(1, (availableCpus * 0.8) as int)
def maxMemoryGB = Math.max(4, (availableMemoryGB * 0.8) as int)

// NOTE: println removed - not compatible with Nextflow 25.10+ strict mode
// System will use: ${maxCpus} CPUs and ${maxMemoryGB} GB memory

// ========================================
// Nextflow Execution Settings
// ========================================

// Enable conda
conda {
    enabled = true
    useMamba = false
    cacheDir = "${launchDir}/.nextflow_cache/conda"
    createTimeout = '2 h'
}

// Execution settings
executor {
    name = 'local'
    cpus = maxCpus
    memory = "${maxMemoryGB} GB"
}

// Resource defaults
process {
    cpus = 1
    memory = '4 GB'
    time = '4 h'
    errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
    maxRetries = 3
    maxErrors = '-1'
}

// Work directory
workDir = "${launchDir}/work"

// Reports and tracing
timeline {
    enabled = true
    file = "${launchDir}/reports/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${launchDir}/reports/report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${launchDir}/reports/trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file = "${launchDir}/reports/dag.html"
    overwrite = true
}

// ========================================
// Pipeline Parameters
// ========================================

params {
    // Input/Output
    reads = null
    lemur_db = null
    outdir = './results'
    
    // Adaptive MAGnet Cutoff Parameters
    // Target fraction of community abundance to capture
    // 0.95 = 95% (faster, fewer references)
    // 0.99 = 99% (default, balanced)
    // 0.999 = 99.9% (comprehensive, more references)
    magnet_target_frac = 0.99
    
    // Adaptive Variant Calling Parameters
    // Minimum coverage to use Clair3 vs bcftools
    // >= this value: use Clair3 (deep learning)
    // < this value: use bcftools (statistical)
    min_cov_for_clair3 = 8
    
    // Clair3 Parameters
    clair3_model = null
    clair3_platform = 'ont'
    
    // Variant Classification Parameters
    af_high = 0.9                 // HIGH confidence: AF >= 0.9
    af_med = 0.7                  // MED confidence: 0.7 <= AF < 0.9
    high_cov_frac = 0.5           // Fraction of median for high coverage
    
    // Contig Building Parameters
    gap_min_cov_frac = 0.1        // Fraction of median coverage to call gap
    gap_min_cov_floor = 2         // Minimum absolute coverage for gap
    gap_min_len = 200             // Minimum gap length to break contigs (bp)
    contig_min_len = 1000         // Minimum contig length to output (bp)
    
    // dRep Parameters
    ani_threshold = 0.95          // ANI threshold for dereplication (0-1)
    
    // Help and Version
    help = false
    version = false
}

// ========================================
// Process-Specific Configuration
// ========================================

process {
    
    // Resource Labels
    withLabel: 'process_single' {
        cpus = 1
        memory = { (2 * task.attempt) + ' GB' }
        time = '1 h'
    }
    
    withLabel: 'process_low' {
        cpus = { Math.min(2, maxCpus) }
        memory = { (4 * task.attempt) + ' GB' }
        time = '2 h'
    }
    
    withLabel: 'process_medium' {
        cpus = { Math.min(4, maxCpus) }
        memory = { (8 * task.attempt) + ' GB' }
        time = '4 h'
    }
    
    withLabel: 'process_high' {
        cpus = { Math.min(8, maxCpus) }
        memory = { (16 * task.attempt) + ' GB' }
        time = '8 h'
    }
    
    withLabel: 'process_ultra' {
        cpus = { maxCpus }
        memory = { (maxMemoryGB * task.attempt) + ' GB' }
        time = '24 h'
    }
    
    // Taxonomic Classification
    withName: 'LEMUR' {
        cpus = { Math.min(8, maxCpus) }
        memory = { (16 * task.attempt) + ' GB' }
        time = '4 h'
    }
    
    // MAGnet Auto-Cutoff
    withName: 'SUGGEST_MAGNET_CUTOFF' {
        cpus = 1
        memory = { (2 * task.attempt) + ' GB' }
        time = '30 min'
    }
    
    // Reference Selection
    withName: 'MAGNET' {
        cpus = { Math.min(8, maxCpus) }
        memory = { (16 * task.attempt) + ' GB' }
        time = '8 h'
    }
    
    withName: 'PARSE_MAGNET_REFS' {
        cpus = 1
        memory = { (1 * task.attempt) + ' GB' }
        time = '30 min'
    }
    
    // Read Alignment
    withName: 'MINIMAP2_ALIGN' {
        cpus = { Math.min(8, maxCpus) }
        memory = { (8 * task.attempt) + ' GB' }
        time = '4 h'
        ext {
            args = '-ax map-ont'
        }
    }
    
    // Coverage Analysis
    withName: 'SAMTOOLS_DEPTH' {
        cpus = 2
        memory = { (4 * task.attempt) + ' GB' }
        time = '2 h'
        ext {
            args = '-aa'
        }
    }
    
    // Adaptive Variant Caller Selection
    withName: 'SELECT_VARIANT_CALLER' {
        cpus = 1
        memory = { (2 * task.attempt) + ' GB' }
        time = '30 min'
    }
    
    // Variant Calling
    withName: 'CLAIR3' {
        cpus = { Math.min(8, maxCpus) }
        memory = { (12 * task.attempt) + ' GB' }
        time = '8 h'
    }
    
    withName: 'BCFTOOLS_CALL' {
        cpus = { Math.min(4, maxCpus) }
        memory = { (8 * task.attempt) + ' GB' }
        time = '4 h'
        ext {
            args = '--skip-variants indels'
        }
    }
    
    // Variant Classification
    withName: 'CLASSIFY_VARIANTS' {
        cpus = 2
        memory = { (4 * task.attempt) + ' GB' }
        time = '2 h'
    }
    
    // Consensus Generation
    withName: 'BCFTOOLS_CONSENSUS' {
        cpus = 2
        memory = { (4 * task.attempt) + ' GB' }
        time = '2 h'
        ext {
            args = '--mark-del N'
        }
    }
    
    // Contig Building
    withName: 'BUILD_CONTIGS' {
        cpus = 2
        memory = { (4 * task.attempt) + ' GB' }
        time = '2 h'
    }
    
    // Genome Dereplication
    withName: 'DREP_DEREPLICATE' {
        cpus = { Math.min(8, maxCpus) }
        memory = { (16 * task.attempt) + ' GB' }
        time = '8 h'
    }
}

// ========================================
// Profiles
// ========================================

profiles {
    
    // Standard profile (conda, auto-detect resources)
    standard {
        conda.enabled = true
    }
    
    // Docker profile (if you prefer containers)
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        conda.enabled = false
    }
    
    // Singularity profile (for HPC environments)
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        conda.enabled = false
    }
    
    // Fast profile (use fewer resources, faster but less accurate)
    fast {
        params.magnet_target_frac = 0.95
        params.min_cov_for_clair3 = 10
    }
    
    // Comprehensive profile (use more resources, slower but more thorough)
    comprehensive {
        params.magnet_target_frac = 0.999
        params.min_cov_for_clair3 = 6
    }
    
    // Test profile (for testing with small data)
    test {
        params.magnet_target_frac = 0.90
        params.contig_min_len = 500
        process.time = '1 h'
        process.memory = '2 GB'
        process.cpus = 1
    }
}

// ========================================
// Manifest
// ========================================

manifest {
    name = 'Marlin Complete'
    author = 'Austin Marshall'
    description = 'Complete Marlin pipeline with adaptive features'
    mainScript = 'marlin_complete.nf'
    version = '1.0.0'
    nextflowVersion = '>=24.04.0'
}