// Enable conda globally
conda {
  enabled = true
  channels = ['conda-forge', 'bioconda', 'defaults']
  useMamba = false
  createArgs = '--solver=libmamba'  // Use libmamba solver for better performance
  createOptions = '-y'
}

// Parameters
params {
    completeness_threshold = 80.0
    max_cpus = 16
    max_memory = '64.GB'
}

// Process configurations
process {
    conda = true
    errorStrategy = 'retry'
    maxRetries = 3  // Increased retries for conda environment creation
    
    // Assembly
    withName: 'SOMATEM_MAGS:FLYE' {
        conda = 'bioconda::flye=2.9.6'
        cpus = 16
        memory = '32.GB'
        time = '12.h'
    }
    
    // Mapping
    withName: 'SOMATEM_MAGS:MINIMAP2_INDEX' {
        conda = 'bioconda::minimap2=2.30'
        cpus = 8
        memory = '16.GB'
    }
    
    withName: 'SOMATEM_MAGS:MINIMAP2_ALIGN' {
        conda = 'bioconda::minimap2=2.30 bioconda::samtools=1.22.1'
        cpus = 8
        memory = '16.GB'
        time = '6.h'
    }
    
    // SAMtools
    withName: 'SOMATEM_MAGS:SAMTOOLS_SORT' {
        conda = 'bioconda::samtools=1.22.1'
        cpus = 4
        memory = '8.GB'
    }
    
    withName: 'SOMATEM_MAGS:SAMTOOLS_COVERAGE' {
        conda = 'bioconda::samtools=1.22.1'
        cpus = 2
        memory = '4.GB'
        ext.args = '-m'
    }
    
    // Binning
    withName: 'SOMATEM_MAGS:SEMIBIN_SINGLEEASYBIN' {
        conda = 'bioconda::semibin=2.2.0'
        cpus = 8
        memory = '32.GB'
        time = '8.h'
    }
    
    // Quality assessment 
    withName: 'SOMATEM_MAGS:CHECKM2_PREDICT' {
        cpus = 4
        memory = '32.GB'
        time = '6.h' 
    }
    
    withName: 'SOMATEM_MAGS:CHECKM2_PARSE' {
        conda = 'conda-forge::python=3.8 conda-forge::pandas=1.5.3 conda-forge::numpy=1.21.6'
        cpus = 1
        memory = '2.GB'
    }
    
    // SingleM
    withName: 'SOMATEM_MAGS:SINGLEM_PIPE' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = 8
        memory = '16.GB'
        time = '4.h'
        ext.taxonomic_profile = true
        ext.otu_table = true
        ext.args = '--min-orf-length 96'
    }
    
    withName: 'SOMATEM_MAGS:SINGLEM_PIPE_BINS' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = 4
        memory = '8.GB'
        ext.otu_table = true
        ext.args = '--min-orf-length 300'
    }
    
    withName: 'SOMATEM_MAGS:SINGLEM_APPRAISE' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = 4
        memory = '8.GB'
        ext.output_binned = true
        ext.output_unbinned = true
        ext.plot = true
        ext.args = '--imperfect --sequence-identity 0.95'
    }
    
    // TaxBurst
    withName: 'SOMATEM_MAGS:TAXBURST' {
        conda = 'bioconda::taxburst=0.3.0'
        cpus = 2
        memory = '4.GB'
    }
    
    // Bakta
    withName: 'SOMATEM_MAGS:BAKTA_BAKTA' {
        conda = 'bioconda::bakta=1.11.3'
        cpus = 24
        memory = '16.GB'
        time = '4.h'
    }
}

// Profiles
profiles {
    conda {
        conda.enabled = true
        conda.useMamba = true
        conda.createTimeout = '2h'  // Global timeout for conda environment creation
        process.conda = true
    }
    
    // Alternative profile with even more conservative CheckM2 setup
    checkm2_safe {
        conda.enabled = true
        conda.useMamba = true
        conda.createTimeout = '2h'
        process.conda = true
        
        process {
            withName: 'SOMATEM_MAGS:CHECKM2_PREDICT' {
                // Most conservative CheckM2 setup
                conda = 'bioconda::checkm2=1.0.1'
                cpus = 8
                memory = '32.GB'
                time = '8.h'
                // Force recreation of environment
                conda.cacheDir = false
            }
        }
    }
}