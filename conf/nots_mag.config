// Enable conda globally
conda {
  enabled = true
  channels = ['conda-forge', 'bioconda', 'defaults']
  useMamba = false
  createArgs = '--solver=libmamba'  // Use libmamba solver for better performance
  createOptions = '-y'
}

// Parameters
// max_cpus and memory: Moved to resourceLimits in base.config 
// other parameters found in nextflow.config

params {
    
    // resource limits (Default, will be overridden)
    resourceLimits = [
        cpus: 90, 
        memory: 250.GB, 
        time: 72.h
    ]
    
}

// Process configurations
process {
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Default resources
    cpus = 1
    memory = '4.GB'
    time = '2.h'
    
    // removed process specific configuration
    // these should be using labels and only ext args etc. 
    // supplied within modules.config file
}

// Profiles
profiles {
    conda {
        conda.enabled = true
        conda.useMamba = true
        conda.createTimeout = '2h'
        process.conda = true
    }
    
    debug {
        process.beforeScript = 'echo $HOSTNAME && which flye && flye --version || echo "Flye not found"'
        cleanup = false
    }
    
    // Alternative profile with even more conservative CheckM2 setup
    checkm2_safe {
        conda.enabled = true
        conda.useMamba = true
        conda.createTimeout = '2h'
        process.conda = true
        
        process {
            withName: 'ASSEMBLY_MAGS:CHECKM2_PREDICT' {
                conda = 'bioconda::checkm2=1.1.0'
                cpus = 8
                memory = '32.GB'
                time = '8.h'
            }
        }
    }
}


