// Enable conda globally
conda {
  enabled = true
  channels = ['conda-forge', 'bioconda', 'defaults']
  useMamba = false
  createArgs = '--solver=libmamba'  // Use libmamba solver for better performance
  createOptions = '-y'
}

// Parameters
params {
    completeness_threshold = 80.0
    max_cpus = 16
    max_memory = '64.GB'
}

// Process configurations
process {
    conda = true
    errorStrategy = 'retry'
    maxRetries = 3  // Increased retries for conda environment creation
    
    // Resource limits and updated software versions moved to `modules.config`
}

// Profiles
profiles {
    conda {
        conda.enabled = true
        conda.useMamba = true
        conda.createTimeout = '2h'  // Global timeout for conda environment creation
        process.conda = true
    }
    
    // Alternative profile with even more conservative CheckM2 setup
    checkm2_safe {
        conda.enabled = true
        conda.useMamba = true
        conda.createTimeout = '2h'
        process.conda = true
        
        process {
            withName: 'SOMATEM_MAGS:CHECKM2_PREDICT' {
                // Most conservative CheckM2 setup
                conda = 'bioconda::checkm2=1.0.1'
                cpus = 8
                memory = '32.GB'
                time = '8.h'
                // Force recreation of environment
                conda.cacheDir = false
            }
        }
    }
}