// Nextflow configuration file for SeqScreen pipeline - Sequential Processing Compatible

// Enable DSL2
nextflow.enable.dsl = 2

// Default parameters
params {
    // Input/Output - UPDATED for sequential subworkflow
    input_dir = null            // NEW: Directory containing FASTA/FASTQ files
    fasta = null               // Keep for backward compatibility
    databases = null
    working = "work"

    // SeqScreen paths
    workflows_dir = null
    bin_dir = null
    module_dir = null

    // Analysis parameters
    mode = "fast"
    threads = 96               // UPDATED: Higher default for sequential processing
    evalue = 10
    bitscore_cutoff = 5
    taxlimit = 25
    splitby = 100000

    // RapSearch2 specific parameters to handle crashes
    max_rapsearch_threads = 16  // Limit rapsearch2 threads to prevent crashes
    min_file_size_mb = 1        // Files smaller than this use conservative settings

    // Execution parameters
    slurm = false
    version = "1.0"
    prefix = ""
    log = "/dev/null"

    // Feature flags
    hmmscan = false
    blastn = false
    ancestral = false
    includecc = false

    // Help
    help = false
}

// Process configuration
process {
    // Default conda environment for all processes
    conda = 'bioconda::seqscreen'

    // Resource defaults
    cpus = { params.threads }
    memory = '4.GB'
    time = '2.h'

    // Error handling - more aggressive for rapsearch2 issues
    errorStrategy = 'retry'
    maxRetries = 3

    // SEQUENTIAL PROCESSING: Enforce one file at a time
    //withName: 'RUN_COMPLETE_SEQSCREEN' {
        //maxForks = 1              // CRITICAL: Only one file at a time
        //cpus = { params.threads } // Full thread allocation per file
        //memory = '32.GB'
        //time = '24.h'             // Longer time for complete pipeline
        //maxRetries = 1
    //}

    // Process-specific configurations for original subworkflow compatibility
    withName: 'RUN_INITIALIZE' {
        maxForks = 1              // Sequential processing
        memory = '2.GB'
        time = '30.min'
        maxRetries = 1
    }

    withName: 'RUN_SEQMAPPER' {
        maxForks = 1              // Sequential processing
        cpus = { params.threads }
        memory = '32.GB'
        time = '4.h'
        maxRetries = 3
    }

    withName: 'RUN_TAXONOMIC_IDENTIFICATION_FAST' {
        maxForks = 1              // Sequential processing
        cpus = { params.threads }
        memory = '120.GB'
        time = '6.h'
    }

    withName: 'RUN_TAXONOMIC_IDENTIFICATION_SENSITIVE' {
        maxForks = 1              // Sequential processing
        cpus = { params.threads }
        memory = '120.GB'
        time = '12.h'
    }

    withName: 'RUN_FUNCTIONAL_ANNOTATION' {
        maxForks = 1              // Sequential processing
        cpus = { params.threads }
        memory = '120.GB'
        time = '8.h'
    }

    withName: 'RUN_REPORT_GENERATION' {
        maxForks = 1              // Sequential processing
        memory = '4.GB'
        time = '1.h'
        maxRetries = 1
    }

    // FASTQ to FASTA conversion process
    //withName: 'FASTQ_TO_FASTA' {
    //    cpus = 1
    //    memory = '1.GB'
    //    time = '30.min'
    //}
}

// Conda configuration
conda {
    enabled = true
    useMamba = true
    createTimeout = '30 min'
    cacheDir = "${launchDir}/conda_cache"
}

// Execution profiles
profiles {

    // Standard profile (default) - UPDATED for sequential processing
    standard {
        process.executor = 'local'
        process.cpus = { params.threads }
        
        // ENFORCE SEQUENTIAL EXECUTION
        executor {
            queueSize = 1         // Only one job at a time
            submitRateLimit = '10 sec'
        }
    }

    // SLURM profile
    slurm {
        process {
            executor = 'slurm'
            queue = 'normal'
            clusterOptions = '--account=your_account'
            
            // SLURM-specific resource requests
            withName: 'RUN_SEQMAPPER' {
                clusterOptions = '--account=your_account --partition=compute'
                time = '4.h'
            }
            
            withName: 'RUN_TAXONOMIC_IDENTIFICATION_SENSITIVE' {
                clusterOptions = '--account=your_account --partition=compute'
                time = '12.h'
            }

            withName: 'RUN_COMPLETE_SEQSCREEN' {
                clusterOptions = '--account=your_account --partition=compute'
                time = '24.h'
            }

            // Conservative SLURM settings for rapsearch2
            withName: 'RAPSEARCH2_BSAT' {
                clusterOptions = '--account=your_account --partition=compute --mem-per-cpu=2G'
                time = '2.h'
            }

            withName: 'RAPSEARCH2_VFDB' {
                clusterOptions = '--account=your_account --partition=compute --mem-per-cpu=2G'
                time = '2.h'
            }
        }
        
        // ENFORCE SEQUENTIAL EXECUTION ON SLURM
        executor {
            queueSize = 1
            submitRateLimit = '30 sec'
        }
    }

    // Docker profile (if needed)
    docker {
        docker.enabled = true
        process.container = 'seqscreen:latest'
    }

    // Singularity profile (if needed)  
    singularity {
        singularity.enabled = true
        process.container = 'seqscreen.sif'
    }

    // Debug profile for troubleshooting - UPDATED for sequential processing
    debug {
        process.executor = 'local'
        process.cpus = 4          // Conservative but not too low
        process.memory = '8.GB'
        
        // Very conservative settings for debugging
        params.max_rapsearch_threads = 4
        params.min_file_size_mb = 10  // Treat most files as small
        params.threads = 4
        
        withName: 'RUN_COMPLETE_SEQSCREEN' {
            maxForks = 1
            memory = '8.GB'
            cpus = 4
            time = '12.h'
        }
        
        withName: 'RAPSEARCH2_BSAT' {
            memory = '2.GB'
            cpus = 2
            time = '1.h'
        }

        withName: 'RAPSEARCH2_VFDB' {
            memory = '2.GB'
            cpus = 2
            time = '1.h'
        }
        
        // ENFORCE SEQUENTIAL EXECUTION IN DEBUG
        executor {
            queueSize = 1
            submitRateLimit = '15 sec'
        }
    }

    // NEW: Ultra-conservative profile for problematic systems
    conservative {
        process.executor = 'local'
        process.cpus = 1
        process.memory = '2.GB'
        
        params.max_rapsearch_threads = 1
        params.min_file_size_mb = 100  // Treat all files as small
        params.threads = 8             // Low but usable
        
        withName: 'RUN_COMPLETE_SEQSCREEN' {
            maxForks = 1
            memory = '4.GB'
            cpus = 8
            time = '48.h'          // Very long timeout
        }
        
        executor {
            queueSize = 1
            submitRateLimit = '30 sec'
        }
    }
}

// Workflow execution settings - UPDATED for sequential processing
executor {
    queueSize = 1              // CRITICAL: Only one job at a time
    submitRateLimit = '10 sec'
}

// Reporting
report {
    enabled = true
    file = "${params.working}/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.working}/execution_timeline.html"
}

trace {
    enabled = true
    file = "${params.working}/execution_trace.txt"
}

dag {
    enabled = true
    file = "${params.working}/pipeline_dag.svg"
}

// Manifest - UPDATED
manifest {
    name = 'Somatem SeqScreen Sequential Subworkflow'
    author = 'Austin G. Marshall'
    homePage = 'https://github.com/treangenlab/somatem'
    description = 'Sequential subworkflow for Somatem SeqScreen analysis with improved rapsearch2 handling and multi-file support'
    mainScript = 'seqscreen_sequential.nf'  // Updated for sequential version
    nextflowVersion = '>=21.04.0'
    version = '1.0.2'
}