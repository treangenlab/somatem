/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    // publishDir for all modules (from nf-core template)
    // publishDir = [
    //     path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
    //     mode: params.publish_dir_mode,
    //     saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    // ]

    // introduce a 2 second delay before running FinalNanoPlot (prevent concurrency issues)
    withName: 'FinalNanoPlot' {
        beforeScript = 'sleep 2'  // 2 second delay
        maxForks = 1
        scratch = true
    }

    // resource limits for nanoplot duplicate process (delay is better than this)
    // withName: '.*NANOPLOT.*' {
    //     maxForks = 1
    //     scratch = true
    // }

    /* ---------------------------
    ext.args for different modules
    --------------------------- */
    
    // Pre-Processing --------------------------------------------------------------------
    

    // matches RawNanoPlot and FinalNanoPlot ; has errors if NANOPLOT is used here
    withName: '.*NanoPlot.*' {
        ext.args = [
            "--maxlength ${params.maxlength}",
            "--minlen ${params.minlen}"
        ].join(' ')
    }

    withName: 'CHOPPER' {
        ext.args2 = [
            "-q ${params.minq}",
            "-l ${params.minlen}"
        ].join(' ')
    }

    withName: 'HOSTILE_FETCH' {
        ext.args = [
            "--minimap2", // download only minimap2 database (for long reads)
        ].join(' ')
    }


    withName: 'HOSTILE_CLEAN' {
        // label = 'process_medium' between low and medium
        cpus = 3
        memory = '18.GB' 
    }


    // taxonomic profiling -----------------------------------------------------------
    withName: 'EMU_ABUNDANCE' {
        ext.args = [
            "--type ${params.seqtype}",
            "--db ${params.emu_db}",
            "--output-dir ./",
            "--min-abundance ${params.min_abundance}",
            "--N ${params.minimap_max_alignments}",
            "--K ${params.minibatch_size}",
            "--keep-counts",
            params.keep_read_assignments ? "--keep-read-assignments" : "",
            params.keep_files ? "--keep-files" : "",
            params.output_unclassified ? "--output-unclassified" : "",
        ].join(' ')                                                           // Join converts the list here to a string.
        ext.prefix = { "${meta.id}" }                                         // A closure can be used to access variables defined in the script
    }

    withName: 'LEMUR' {
        ext.args = [
            "--rank ${params.rank}",
            "--db-prefix ${params.lemur_db}",
            "--tax-path ${params.lemur_taxonomy}",
        ].join(' ')                                                           // Join converts the list here to a string.
    }

    withName: 'MAGNET' {
        ext.args = [
            "-a 12", // clarify the abundance column from lemur output
        ].join(' ')                                                           // Join converts the list here to a string.
    }

    // genome-dynamics -----------------------------------------------------------
    withName: 'RHEA' {
        ext.args = [
            "--output-dir ./", // output to current directory
        ].join(' ')
    }

    // MAG/assembly Workflow ----------------------------------------------------------
    // checkm2
    withName: 'CHECKM2_DATABASEDOWNLOAD' {
        storeDir = params.checkm2_db
    }

    // bakta
    withName: 'BAKTA_BAKTADBDOWNLOAD' {
        storeDir = params.bakta_db
    }

    // singlem
    withName: 'SINGLEM_DOWNLOAD_DB' {
        storeDir = params.singlem_db
    }

    // Resource limits and updated software versions ----
    // Assembly
    withName: 'FLYE' {
        conda = 'bioconda::flye=2.9.6' // updated from nf-core's v2.9.5
        memory = { 36.GB * task.attempt } // halved from process_high's memory of 72 GB
    }
    
    // Mapping
    withName: 'SOMATEM_MAGS:MINIMAP2_INDEX' {
        conda = 'bioconda::minimap2=2.30' // updated from nf-core's v2.29
        cpus = 8
        memory = '16.GB'
    }
    
    withName: 'SOMATEM_MAGS:MINIMAP2_ALIGN' {
        conda = 'bioconda::minimap2=2.30 bioconda::samtools=1.22.1'
        cpus = 8
        memory = '16.GB'
        time = '6.h'
    }
    
    // SAMtools
    withName: 'SOMATEM_MAGS:SAMTOOLS_SORT' {
        conda = 'bioconda::samtools=1.22.1'
        cpus = 4
        memory = '8.GB'
    }
    
    withName: 'SOMATEM_MAGS:SAMTOOLS_COVERAGE' {
        conda = 'bioconda::samtools=1.22.1'
        cpus = 2
        memory = '4.GB'
        ext.args = '-m'
    }
    
    // Binning
    withName: 'SOMATEM_MAGS:SEMIBIN_SINGLEEASYBIN' {
        conda = 'bioconda::semibin=2.2.0'
        cpus = 8
        memory = '32.GB'
        time = '8.h'
    }
    
    // Quality assessment 
    withName: 'SOMATEM_MAGS:CHECKM2_PREDICT' {
        cpus = 4
        memory = '32.GB'
        time = '6.h' 
    }
    
    withName: 'SOMATEM_MAGS:CHECKM2_PARSE' {
        conda = 'conda-forge::python=3.8 conda-forge::pandas=1.5.3 conda-forge::numpy=1.21.6'
        cpus = 1
        memory = '2.GB'
    }
    
    // SingleM
    withName: 'SOMATEM_MAGS:SINGLEM_PIPE' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = 8
        memory = '16.GB'
        time = '4.h'
        ext.taxonomic_profile = true
        ext.otu_table = true
        ext.args = '--min-orf-length 96'
    }
    
    withName: 'SOMATEM_MAGS:SINGLEM_PIPE_BINS' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = 4
        memory = '8.GB'
        ext.otu_table = true
        ext.args = '--min-orf-length 300'
    }
    
    withName: 'SOMATEM_MAGS:SINGLEM_APPRAISE' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = 4
        memory = '8.GB'
        ext.output_binned = true
        ext.output_unbinned = true
        ext.plot = true
        ext.args = '--imperfect --sequence-identity 0.95'
    }
    
    // TaxBurst
    withName: 'SOMATEM_MAGS:TAXBURST' {
        conda = 'bioconda::taxburst=0.3.0'
        cpus = 2
        memory = '4.GB'
    }
    
    // Bakta
    withName: 'SOMATEM_MAGS:BAKTA_BAKTA' {
        conda = 'bioconda::bakta=1.11.3'
        cpus = 24
        memory = '16.GB'
        time = '4.h'
    }
}
