// Comprehensive conda-enabled configuration for SOMATEM_MAGS workflow
// This configuration enables conda for all processes and sets appropriate resources

// Global conda settings
conda {
    enabled = true
    //useMamba = true  // Use mamba for faster environment creation
    createTimeout = '1h'  // Allow more time for environment creation
    cacheDir = "${HOME}/.nextflow/conda"  // Cache conda environments
}

// Global parameters
params {
    // Completeness threshold for generating Bakta plots (default: 80%)
    completeness_threshold = 80.0
    
    // Maximum resources (adjust based on your system)
    max_cpus = 16
    max_memory = '64.GB'
    max_time = '24.h'
}

// Process-specific configurations
process {
    
    // Global process settings
    conda = true
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Resource limits
    cpus = { check_max(4, 'cpus') }
    memory = { check_max(8.GB * task.attempt, 'memory') }
    time = { check_max(4.h * task.attempt, 'time') }
    
    // nf-core modules - Assembly
    withName: 'SOMATEM_MAGS:FLYE' {
        conda = 'bioconda::flye=2.9.6'
        cpus = { check_max(8, 'cpus') }
        memory = { check_max(32.GB * task.attempt, 'memory') }
        time = { check_max(12.h * task.attempt, 'time') }
        ext.args = '--iterations 2'
        publishDir = [
            path: { "${params.output_dir}/assembly" },
            mode: 'copy',
            pattern: '*.{fasta,gfa,log}'
        ]
    }
    
    // nf-core modules - Mapping
    withName: 'SOMATEM_MAGS:MINIMAP2_INDEX' {
        conda = 'bioconda::minimap2=2.30'
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
        publishDir = [
            path: { "${params.output_dir}/mapping/index" },
            mode: 'copy',
            pattern: '*.mmi'
        ]
    }
    
    withName: 'SOMATEM_MAGS:MINIMAP2_ALIGN' {
        conda = 'bioconda::minimap2=2.30'
        cpus = { check_max(8, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(6.h * task.attempt, 'time') }
        ext.args = '-ax map-ont'
        publishDir = [
            path: { "${params.output_dir}/mapping" },
            mode: 'copy',
            pattern: '*.bam'
        ]
    }
    
    // nf-core modules - SAMtools
    withName: 'SOMATEM_MAGS:SAMTOOLS_SORT' {
        conda = 'bioconda::samtools=1.22.1'
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
        ext.args = '-@ 4'
        publishDir = [
            path: { "${params.output_dir}/mapping" },
            mode: 'copy',
            pattern: '*.sorted.bam'
        ]
    }
    
    withName: 'SOMATEM_MAGS:SAMTOOLS_COVERAGE' {
        conda = 'bioconda::samtools=1.22.1'
        cpus = { check_max(2, 'cpus') }
        memory = { check_max(4.GB * task.attempt, 'memory') }
        time = { check_max(1.h * task.attempt, 'time') }
        ext.args = '-m'  // Include mean depth
        publishDir = [
            path: { "${params.output_dir}/coverage" },
            mode: 'copy',
            pattern: '*.txt'
        ]
    }
    
    // nf-core modules - Binning
    withName: 'SOMATEM_MAGS:SEMIBIN_SINGLEEASYBIN' {
        conda = 'bioconda::semibin=2.2.0'
        cpus = { check_max(8, 'cpus') }
        memory = { check_max(32.GB * task.attempt, 'memory') }
        time = { check_max(8.h * task.attempt, 'time') }
        ext.args = '--sequencing-type long_read'
        publishDir = [
            path: { "${params.output_dir}/binning" },
            mode: 'copy',
            pattern: '*.{fa,fasta,csv,tsv}'
        ]
    }
    
    // nf-core modules - Quality assessment
    withName: 'SOMATEM_MAGS:CHECKM2_PREDICT' {
        conda = 'bioconda::checkm2=1.1.0'
        cpus = { check_max(8, 'cpus') }
        memory = { check_max(32.GB * task.attempt, 'memory') }
        time = { check_max(6.h * task.attempt, 'time') }
        ext.args = '--force'
        publishDir = [
            path: { "${params.output_dir}/quality/checkm2" },
            mode: 'copy',
            pattern: '*.{tsv,log}'
        ]
    }
    
    // Local modules - CheckM2 parsing
    withName: 'SOMATEM_MAGS:CHECKM2_PARSE' {
        conda = 'conda-forge::python=3.9 conda-forge::pandas=2.0.3'
        cpus = { check_max(1, 'cpus') }
        memory = { check_max(2.GB * task.attempt, 'memory') }
        time = { check_max(30.min * task.attempt, 'time') }
        publishDir = [
            path: { "${params.output_dir}/quality" },
            mode: 'copy',
            pattern: '*.csv'
        ]
    }
    
    // Local modules - SingleM pipe on metagenome reads
    withName: 'SOMATEM_MAGS:SINGLEM_PIPE' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = { check_max(8, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(4.h * task.attempt, 'time') }
        ext.taxonomic_profile = true
        ext.otu_table = true
        ext.args = '--min-orf-length 96'
        publishDir = [
            path: { "${params.output_dir}/singlem_metagenome" },
            mode: 'copy',
            pattern: '*.{tsv,csv}'
        ]
    }
    
    // Local modules - SingleM pipe on bins/genomes
    withName: 'SOMATEM_MAGS:SINGLEM_PIPE_BINS' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
        ext.otu_table = true
        ext.args = '--min-orf-length 300'  // Higher threshold for genomes
        publishDir = [
            path: { "${params.output_dir}/singlem_bins" },
            mode: 'copy',
            pattern: '*.csv'
        ]
    }
    
    // Local modules - SingleM appraise
    withName: 'SOMATEM_MAGS:SINGLEM_APPRAISE' {
        conda = 'bioconda::singlem=0.19.0'
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
        ext.output_binned = true
        ext.output_unbinned = true
        ext.plot = true
        ext.args = '--imperfect --sequence-identity 0.95'
        publishDir = [
            path: { "${params.output_dir}/singlem_appraise" },
            mode: 'copy',
            pattern: '*.{txt,csv,svg}'
        ]
    }
    
    // Local modules - TaxBurst
    withName: 'SOMATEM_MAGS:TAXBURST' {
    //    conda = 'bioconda::taxburst=0.3.0' install thru pip env instead
        cpus = { check_max(2, 'cpus') }
        memory = { check_max(4.GB * task.attempt, 'memory') }
        time = { check_max(1.h * task.attempt, 'time') }
        ext.args = '--save-json'
        publishDir = [
            path: { "${params.output_dir}/taxonomy" },
            mode: 'copy',
            pattern: '*.{html,json}'
        ]
    }
    
    // Local modules - Bakta annotation with conditional plot generation
    withName: 'SOMATEM_MAGS:BAKTA_BAKTA' {
        conda = 'bioconda::bakta=1.11.3'
        cpus = { check_max(8, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(4.h * task.attempt, 'time') }
        // Note: --skip-plot is handled dynamically in the process based on completeness
        ext.args = '--meta --compliant'
        publishDir = [
            [
                path: { "${params.output_dir}/annotation/bakta/${meta.id}" },
                mode: 'copy',
                pattern: '*.{embl,faa,ffn,fna,gbff,gff3,tsv,txt,json,hypotheticals.tsv,hypotheticals.faa,inference.tsv}'
            ],
            [
                path: { "${params.output_dir}/annotation/bakta/${meta.id}/plots" },
                mode: 'copy',
                pattern: '*.{png,svg}',
                enabled: { meta.completeness != null && meta.completeness >= params.completeness_threshold }
            ]
        ]
    }
}

// Profiles for different execution environments
profiles {
    
    // Standard conda profile (default)
    conda {
        conda.enabled = true
        //conda.useMamba = true
        process.conda = true
    }
    
    // Local execution with conda
    local {
        conda.enabled = true
        conda.useMamba = true
        process.conda = true
        process.executor = 'local'
        process.cpus = { check_max(params.max_cpus, 'cpus') }
        process.memory = { check_max(params.max_memory, 'memory') }
    }
    
    // SLURM cluster with conda
    slurm {
        conda.enabled = true
        conda.useMamba = true
        process.conda = true
        process.executor = 'slurm'
        process.queue = 'normal'
        process.clusterOptions = '--account=your_account'
    }
    
    // PBS/Torque cluster with conda
    pbs {
        conda.enabled = true
        conda.useMamba = true
        process.conda = true
        process.executor = 'pbs'
        process.queue = 'normal'
    }
    
    // SGE cluster with conda
    sge {
        conda.enabled = true
        conda.useMamba = true
        process.conda = true
        process.executor = 'sge'
        process.queue = 'all.q'
    }
}

// Resource checking function
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}

// Cleanup settings
cleanup = true

// Report settings
report {
    enabled = true
    file = "${params.output_dir}/pipeline_info/execution_report.html"
}

timeline {
    enabled = true
    file = "${params.output_dir}/pipeline_info/execution_timeline.html"
}

trace {
    enabled = true
    file = "${params.output_dir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled = true
    file = "${params.output_dir}/pipeline_info/pipeline_dag.svg"
}

// Manifest
manifest {
    name = 'SOMATEM_MAGS'
    description = 'Metagenomics analysis workflow with taxonomic profiling, assembly, binning, and annotation'
    version = '1.0.0'
    nextflowVersion = '>=23.04.0'
    homePage = 'https://github.com/treangenlab/Somatem'
    author = 'Your Name'
    mainScript = 'main.nf'
}