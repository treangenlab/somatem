#!/usr/bin/env bash
set -euo pipefail

PIPELINE_DIR="@@PIPELINE_DIR@@"

show_help() {
    cat <<EOF
Somatem

Usage:
  somatem <command> [nextflow args...]

Commands:
  pre_processing        Run the pre-processing workflow
  mag                   Run the MAG assembly workflow
  taxonomic_profiling   Run the taxonomic profiling workflow
  genome_dynamics       Run the genome dynamics workflow
  get_example_data      Download example data
  download_databases    Download required databases
  help                  Show this help message

Examples:
  somatem pre_processing --help
  somatem mag --help
  somatem taxonomic_profiling --help
  somatem genome_dynamics --help
  somatem get_example_data --outdir ./somatem_example_data
  somatem download_databases --help
EOF
}

cmd="${1:-help}"
if [[ $# -gt 0 ]]; then
    shift
fi

case "${cmd}" in
    pre_processing|pre-processing|preprocessing)
        exec nextflow run "${PIPELINE_DIR}/subworkflows/local/pre-processing.nf" "$@"
        ;;
    mag|assembly_mags|mag_assembly|assembly)
        exec nextflow run "${PIPELINE_DIR}/subworkflows/local/assembly_mags.nf" "$@"
        ;;
    taxonomic_profiling|taxonomic-profiling|tax|profiling)
        exec nextflow run "${PIPELINE_DIR}/subworkflows/local/taxonomic-profiling.nf" "$@"
        ;;
    genome_dynamics|genome-dynamics|dynamics)
        exec nextflow run "${PIPELINE_DIR}/subworkflows/local/genome-dynamics.nf" "$@"
        ;;
    get_example_data|example_data|examples)
        exec nextflow run "${PIPELINE_DIR}/subworkflows/local/get_example_data.nf" "$@"
        ;;
    download_databases|download-databases|databases|dbs)
        exec nextflow run "${PIPELINE_DIR}/subworkflows/local/download_databases.nf" "$@"
        ;;
    help|-h|--help)
        show_help
        ;;
    *)
        echo "Error: unknown command '${cmd}'" >&2
        echo >&2
        show_help >&2
        exit 1
        ;;
esac